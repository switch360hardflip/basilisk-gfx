	    <macro><name>#define FE_16(WHAT, X, ...)</name><line>WHAT(X) FE_15(WHAT, __VA_ARGS__)</line></macro>
		<macro><name>#define GET_MACRO(_0,_1,_2,_3,_4,_5,_6,_7,_8,_9,_10,_11,_12,_13,_14,_15,_16,NAME,...)</name><line>NAME</line></macro>
	    <macro>
			<name>#define __VA_FOR__(action, ...)</name>
			<line>GET_MACRO(_0, __VA_ARGS__,</line>
