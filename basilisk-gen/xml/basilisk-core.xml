        <macro><name>#define FE2_16(WHAT, a, b, ...)</name><line>WHAT(a, b) FE2_14(WHAT, __VA_ARGS__)</line></macro>

        <macro><name>#define GET_FE2_MACRO(_1,_2,_3,_4,_5,_6,_7,_8,_9,_10,_11,_12,_13,_14,_15,_16,NAME,...)</name><line>NAME</line></macro>
		
		<macro>
			<name>#define __VA_FOR_2__(action, ...)</name>
