        <macro>
            <name>#define BSGFX_PARSE_FORMAT(format, data, len)</name>
            <line>    do {</line>
            <line>        va_list args;</line>
            <line>        va_start(args, format);</line>
            <line>        len = vsnprintf(NULL, 0, format, args);</line>
            <line>        va_end(args);</line>
            <line>        if (len &gt;= (sizeof(data) / sizeof(*data))) {</line>
            <line>            bs_throwBasiliskF(BSX_OUT_OF_BOUNDS,</line>
            <line>                "Format %s has a limit of %d characters",</line>
            <line>                format, sizeof(data) - 1);</line>
            <line>        }</line>
            <line>        va_start(args, format);</line>
            <line>        vsprintf(data, format, args);</line>
            <line>        va_end(args);</line>
            <line>    } while (0)</line>
        </macro>

